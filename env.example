# ================================
# LLMHive Environment Variables
# ================================
# Copy this file to .env.local and fill in your values

# ================================
# REQUIRED - Authentication (Clerk)
# ================================
# Localhost: use Development keys (pk_test_ / sk_test_) from Clerk Dashboard.
# pk_live_ / sk_live_ only work on production domains (e.g. llmhive.ai), not http://localhost:3000.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Vercel: If CLERK_SECRET_KEY shows "Needs Attention", the value is usually empty, a
# placeholder, or the wrong key type for an environment. Use sk_test_* with
# pk_test_* for Development (and local .env.local). Use sk_live_* with pk_live_* for
# Production (and Preview if it hits llmhive.ai). Prefer separate Vercel rows per
# environment instead of one "All Environments" secret when test vs live differ.

# Clerk URLs (sign-in / sign-up paths)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Do not set NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL / AFTER_SIGN_UP — Clerk maps them to
# deprecated props. Post-sign-in redirects live on <ClerkProvider> in app/layout.tsx
# (signInFallbackRedirectUrl, signUpForceRedirectUrl, etc.).

# ================================
# REQUIRED - Stripe (Payments)
# ================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ================================
# Stripe Price IDs - 4-Tier Pricing (January 2026)
# Create these products/prices in your Stripe dashboard
# ================================

# Lite Tier ($9.99/mo, $99.99/yr) - Uses "BASIC" name for backwards compatibility
STRIPE_PRICE_ID_BASIC_MONTHLY=price_...
STRIPE_PRICE_ID_BASIC_ANNUAL=price_...

# Pro Tier ($29.99/mo, $299.99/yr)
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...

# Enterprise Tier ($35/seat/mo, $350/seat/yr - min 5 seats)
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ID_ENTERPRISE_ANNUAL=price_...

# Maximum Tier ($499/mo, $4,999/yr)
STRIPE_PRICE_ID_MAXIMUM_MONTHLY=price_...
STRIPE_PRICE_ID_MAXIMUM_ANNUAL=price_...

# Admin User IDs (comma-separated Clerk user IDs for admin access)
ADMIN_USER_IDS=user_...

# ================================
# REQUIRED - Backend API
# ================================
# URL to your FastAPI backend (Cloud Run in production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ORCHESTRATOR_API_BASE_URL=https://your-service.run.app
# Alternative variable names (for compatibility)
ORCHESTRATION_API_BASE=http://localhost:8000
LLMHIVE_API_URL=http://localhost:8000
# Same value as the orchestrator's API_KEY (GCP Secret Manager / Cloud Run). Vercel
# server routes send X-API-Key: LLMHIVE_API_KEY. Set for Production, Preview, and
# Development if you run server features against a real backend; "Needs Attention"
# on the Development row usually means this row is empty.
LLMHIVE_API_KEY=

# ================================
# RECOMMENDED - Error Tracking (Sentry)
# ================================
# Sentry is pre-configured! Just add your DSN to enable.
# 1. Create account at https://sentry.io
# 2. Create a Next.js project
# 3. Copy your DSN below
# 4. (Optional) Add org/project for source maps upload
# Leave unset until you have a real DSN (placeholder values cause noisy "Invalid Sentry Dsn" logs).
# NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-org-name
SENTRY_PROJECT=llmhive
SENTRY_AUTH_TOKEN=sntrys_...

# ================================
# RECOMMENDED - Transactional Emails (Resend)
# ================================
# Used for welcome emails, subscription confirmations, etc.
# 1. Create account at https://resend.com
# 2. Get API key from dashboard
# 3. Verify your domain for production
RESEND_API_KEY=re_...
# From email address (must be verified domain in production)
# Domain verified: contact.llmhive.ai
EMAIL_FROM=LLMHive <noreply@contact.llmhive.ai>

# ================================
# OPTIONAL - Analytics
# ================================
# Vercel Analytics is enabled by default when deployed to Vercel
# PostHog (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ================================
# OPTIONAL - Notifications (Slack)
# ================================
# Slack webhook URL for real-time alerts (support tickets, subscriptions, etc.)
# Create at: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ================================
# OPTIONAL - AI Provider Keys
# ================================
# These are typically configured in your backend, but can be used for direct client calls
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
TOGETHERAI_API_KEY=...

# ================================
# OPTIONAL - Feature Flags
# ================================
NEXT_PUBLIC_ENABLE_BENCHMARKS=false
NEXT_PUBLIC_ENABLE_ADMIN=false

# ================================
# DEVELOPMENT
# ================================
# Enable debug mode
DEBUG=false
# Node environment
NODE_ENV=development

# ================================
# PRODUCTION ONLY
# ================================
# Your production domain (required for some features)
NEXT_PUBLIC_APP_URL=https://llmhive.ai

# ================================
# NOT USED BY THIS REPO (safe to delete in Vercel)
# ================================
# The Next.js app uses Clerk only (no next-auth). If AUTH_SECRET, GITHUB_SECRET, or
# GITHUB_ID exist in Vercel from a template, they are unused; remove them or Vercel
# may keep showing "Needs Attention" for empty/invalid values.


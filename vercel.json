{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.llmhive.ai" }],
      "destination": "https://llmhive.ai/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-optimize",
      "schedule": "0 4 * * 0"
    }
  ]
}

